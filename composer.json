{
    "name": "nawasara/database-monitor",
    "description": "MySQL/MariaDB server + database monitoring for the Nawasara superapp framework — inventory, capacity, performance, slow query, and alerting via a single read-only monitoring user.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "nawasara",
        "laravel",
        "mysql",
        "mariadb",
        "monitoring",
        "database",
        "observability"
    ],
    "authors": [
        {
            "name": "Pringgo J. Saputro",
            "email": "odyinggo@gmail.com",
            "role": "Lead Developer"
        }
    ],
    "support": {
        "issues": "https://github.com/nawasara/database-monitor/issues",
        "source": "https://github.com/nawasara/database-monitor"
    },
    "autoload": {
        "psr-4": {
            "Nawasara\\DatabaseMonitor\\": "src/"
        }
    },
    "require": {
        "php": "^8.1",
        "ext-pdo": "*",
        "illuminate/support": "^10.0|^12.0",
        "spatie/laravel-permission": "^6.0",
        "nawasara/ui": "*",
        "nawasara/sync": "*",
        "nawasara/vault": "*",
        "nawasara/notification": "*",
        "nawasara/alerting": "*",
        "nawasara/auth-primitives": "*",
        "livewire/livewire": "^3.0"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Nawasara\\DatabaseMonitor\\DatabaseMonitorServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
